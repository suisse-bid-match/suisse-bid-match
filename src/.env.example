# App
APP_NAME=Suisse Bid Match
APP_ENV=dev
LOG_LEVEL=INFO

# Database (Postgres-only)
DB_REQUIRE_POSTGRES=true
DB_URL=postgresql+psycopg://suisse:suisse@localhost:5432/suisse_bid_match
# Optional: used by docker compose for the api container
# DB_URL_DOCKER=postgresql+psycopg://suisse:suisse@postgres:5432/suisse_bid_match
POSTGRES_DB=suisse_bid_match
POSTGRES_USER=suisse
POSTGRES_PASSWORD=suisse

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=tender_chunks
QDRANT_TIMEOUT=30
QDRANT_RECREATE_COLLECTION=false

# Embeddings
EMBEDDING_BACKEND=local
# Legacy fallback (used if *_API_KEY vars below are empty)
OPENAI_API_KEY=
# Used for Chat/Checklist answer generation
OPENAI_CHAT_API_KEY=
# Used only when EMBEDDING_BACKEND=openai
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM
OPENAI_CHAT_MODEL=gpt-5-mini
LLM_MATCHING_ENABLED=true
LLM_MATCH_POOL_SIZE=12

# SIMAP
SIMAP_BASE_URL=https://www.simap.ch
SIMAP_TOKEN=
SIMAP_TIMEOUT_SECONDS=20
SIMAP_RPS=1.0
SIMAP_PUBLICATIONS_PATH=/api/publications/v2/project/project-search
SIMAP_PUBLICATION_DETAIL_PATH=/api/publications/v1/project/{projectId}/publication-details/{publicationId}

# Paths
DOCS_STORAGE_ROOT=./data/docs

# Retrieval
DENSE_WEIGHT=0.7
BM25_WEIGHT=0.3
DEFAULT_TOP_K=8
DENSE_CANDIDATES=30
CHAT_MAX_RETRIEVAL_ROUNDS=1

# Feature flags
ENABLE_DEBUG_CHAT=true
PRELOAD_LOCAL_EMBEDDING_ON_STARTUP=true
